# ─────────────────────────────────────────────────────────
# ArgoCD Application Manifest Template
# ─────────────────────────────────────────────────────────
# Dynamic parameters configuration for GitOps synchronization.
# Depends on Jinja2 templating for inventory hostname injection
# into Helm values.
# the Helm values.
# ─────────────────────────────────────────────────────────

apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: platform-app
  namespace: argocd
spec:
  project: default
  source:
    repoURL: '{{ github_repo_url }}'
    targetRevision: HEAD
    path: platform-chart
    helm:
      values: |
        ingress:
          enabled: true
          className: traefik
          host: {{ inventory_hostname }}.nip.io
  destination:
    server: 'https://kubernetes.default.svc'
    namespace: '{{ app_namespace }}'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
