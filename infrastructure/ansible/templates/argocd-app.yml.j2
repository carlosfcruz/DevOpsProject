# ─────────────────────────────────────────────────────────
# ArgoCD Application Manifest Template
# ─────────────────────────────────────────────────────────
# This template defines the GitOps synchronization parameters
# for the platform application. It uses Jinja2 templating
# notation ({{ variable_name }}) to dynamically inject the 
# target server IP into the Helm values.
# ─────────────────────────────────────────────────────────

apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: platform-app
  namespace: argocd
spec:
  project: default
  source:
    repoURL: '{{ github_repo_url }}'
    targetRevision: HEAD
    path: app/chart
    helm:
      values: |
        ingress:
          enabled: true
          hosts:
            # We inject the Ansible inventory hostname (the EC2 public IP)
            - host: {{ inventory_hostname }}.nip.io
              paths:
                - path: /
                  pathType: Prefix
  destination:
    server: 'https://kubernetes.default.svc'
    namespace: '{{ app_namespace }}'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
