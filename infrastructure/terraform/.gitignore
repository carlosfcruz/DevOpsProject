# Terraform local state files — NEVER commit these
*.tfstate
*.tfstate.backup

# Terraform working directory (downloaded providers)
.terraform/

# Lock file is fine to commit (pins provider versions)
# !.terraform.lock.hcl

# Variable files may contain secrets
*.tfvars
!staging.tfvars

# SSH keys generated by Terraform
*.pem

# Crash logs
crash.log
crash.*.log
